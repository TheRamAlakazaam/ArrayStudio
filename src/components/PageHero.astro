---
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<section class="relative overflow-hidden border-b border-black/8 bg-[#f3fafe]">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-x-0 top-0 h-px bg-black/6"></div>
    <div class="absolute right-0 top-0 h-full w-[32rem] bg-[radial-gradient(circle_at_top_right,rgba(135,206,235,0.24),transparent_62%)]"></div>
  </div>

  <div class="relative mx-auto max-w-[1440px] px-6 pb-12 pt-16 md:px-10 md:pb-14 md:pt-20 lg:px-12 lg:pb-16 lg:pt-22">
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <div>
        <p class="font-mono text-[11px] uppercase tracking-[0.28em] text-[#ff6b4a]">{eyebrow}</p>
        <h1 class="display-title mt-4 max-w-[16ch] text-[clamp(36px,5vw,64px)] text-black">
          {title}
        </h1>
      </div>

      <div class="content-panel p-5 md:p-6">
        <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-black/38">Approach</p>
        <p class="mt-3 max-w-[42rem] font-mono text-[14px] leading-[1.9] text-black/68 md:text-[15px]">
          {intro}
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="rounded-full border border-black/10 bg-[#e8f7fd] px-3 py-2 font-mono text-[10px] uppercase tracking-[0.18em] text-black/62">
            Strategy
          </span>
          <span class="rounded-full border border-black/10 bg-white px-3 py-2 font-mono text-[10px] uppercase tracking-[0.18em] text-black/62">
            Storytelling
          </span>
          <span class="rounded-full border border-black/10 bg-white px-3 py-2 font-mono text-[10px] uppercase tracking-[0.18em] text-black/62">
            Rollout
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

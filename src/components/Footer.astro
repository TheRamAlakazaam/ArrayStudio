---
const links = [
  { label: "Story", href: "#story" },
  { label: "Services", href: "#services" },
  { label: "Process", href: "#process" },
  { label: "FAQ", href: "#faq" },
  { label: "Contact", href: "mailto:hello@arraystudio.com" },
];

const year = new Date().getFullYear();
---

<footer class="bg-cream px-12 py-12 flex justify-between items-center border-t border-light-gray">
  <div>
    <a href="#" class="font-bebas text-[28px] tracking-[0.15em] text-black no-underline">
      Array Studio
    </a>
    <p class="font-mono text-[11px] tracking-[0.1em] text-mid-gray mt-1">
      Visual storytelling for brands that mean it.
    </p>
  </div>

  <ul class="flex gap-8 list-none">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-mono text-[11px] tracking-[0.12em] uppercase text-mid-gray no-underline hover:text-black transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <p class="font-mono text-[10px] text-light-gray tracking-[0.1em]">
    © {year} Array Studio. All rights reserved.
  </p>
</footer>

---
const pathname = Astro.url.pathname;

const links = [
  { label: "About", href: "/about/" },
  { label: "Services", href: "/services/" },
  { label: "Work", href: "/work/" },
  { label: "Blog", href: "/blog/" },
  { label: "Contact", href: "/contact/" },
];
---

<header class="sticky top-0 z-50 px-4 pt-4 md:px-6">
  <nav class="mx-auto max-w-[1440px] rounded-[1.35rem] border border-black/8 bg-warm-white/90 px-6 py-4 shadow-[0_10px_30px_rgba(17,28,36,0.06)] backdrop-blur-xl md:px-8 lg:px-10">
    <div class="flex items-center justify-between gap-4">
      <a href="/" class="font-bebas text-[24px] font-bold tracking-[-0.05em] text-black no-underline">
        Array Studio
      </a>

      <div class="hidden items-center gap-2 md:flex">
        {
          links.map((link) => {
            const isActive = pathname === link.href;

            return (
              <a
                href={link.href}
                class:list={[
                  "rounded-full px-4 py-2 font-mono text-[11px] uppercase tracking-[0.18em] no-underline transition-colors duration-200",
                  isActive ? "bg-black text-white" : "text-black/62 hover:bg-sky-100 hover:text-black",
                ]}
              >
                {link.label}
              </a>
            );
          })
        }
      </div>

      <a
        href="/contact/"
        class="inline-flex items-center justify-center rounded-full bg-[#ff6b4a] px-5 py-3 font-mono text-[11px] uppercase tracking-[0.18em] text-white no-underline transition-transform duration-200 hover:-translate-y-0.5"
      >
        Start a Project
      </a>
    </div>

    <div class="mt-4 flex flex-wrap gap-2 md:hidden">
      {
        links.map((link) => {
          const isActive = pathname === link.href;

          return (
            <a
              href={link.href}
              class:list={[
                "rounded-full border px-3 py-2 font-mono text-[10px] uppercase tracking-[0.18em] no-underline transition-colors duration-200",
                isActive
                  ? "border-black bg-black text-white"
                  : "border-black/10 bg-white/70 text-black/68 hover:border-black/20 hover:bg-sky-100 hover:text-black",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>

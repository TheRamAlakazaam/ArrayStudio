---
const items = ["Film It", "Shoot It", "Brand It", "Mean It"];
const allItems = [...items, ...items, ...items];
---

<div class="bg-red overflow-hidden flex py-5">
  <div class="animate-ticker-fast flex gap-20 whitespace-nowrap">
    {
      allItems.map((item, i) => (
        <>
          <span class="font-bebas text-[28px] tracking-[0.12em] text-cream">{item}</span>
          <span class="font-bebas text-[28px] text-black">✦</span>
        </>
      ))
    }
  </div>
</div>

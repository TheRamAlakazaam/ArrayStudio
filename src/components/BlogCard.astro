---
interface Props {
  href: string;
  category: string;
  title: string;
  description: string;
  publishDate: string;
}

const { href, category, title, description, publishDate } = Astro.props;
---

<a
  href={href}
  class="content-panel group block p-5 no-underline transition-transform duration-200 hover:-translate-y-0.5 md:p-6"
>
  <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#ff6b4a]">{category}</p>
  <h3 class="mt-3 font-bebas text-[30px] font-bold leading-[0.98] tracking-[-0.05em] text-black">
    {title}
  </h3>
  <p class="mt-3 font-mono text-[13px] leading-[1.85] text-black/62">{description}</p>
  <p class="mt-5 font-mono text-[10px] uppercase tracking-[0.22em] text-black/38">{publishDate}</p>
</a>

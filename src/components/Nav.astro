---
const links = [
  { label: "Our Story", href: "#story" },
  { label: "Services", href: "#services" },
  { label: "Process", href: "#process" },
  { label: "FAQ", href: "#faq" },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-12 py-5 transition-all duration-300"
>
  <a
    href="#"
    class="font-bebas text-[22px] tracking-[0.15em] text-cream transition-colors duration-300"
    id="nav-logo"
  >
    Array Studio
  </a>

  <ul class="flex gap-9 list-none items-center">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link font-mono text-[11px] tracking-[0.12em] uppercase text-cream opacity-80 hover:opacity-100 transition-opacity duration-200 no-underline"
          >
            {link.label}
          </a>
        </li>
      ))
    }
    <li>
      <a
        href="mailto:hello@arraystudio.com"
        class="nav-link font-mono text-[11px] tracking-[0.12em] uppercase text-cream border border-cream/40 px-[18px] py-2 hover:bg-cream hover:text-black transition-all duration-200 no-underline"
      >
        Let's Talk.
      </a>
    </li>
  </ul>
</nav>

<script>
  const nav = document.getElementById("main-nav");
  const logo = document.getElementById("nav-logo");
  const navLinks = document.querySelectorAll(".nav-link");

  window.addEventListener("scroll", () => {
    if (window.scrollY > window.innerHeight - 80) {
      nav!.style.background = "rgba(250,248,244,0.95)";
      nav!.style.backdropFilter = "blur(12px)";
      nav!.style.borderBottom = "1px solid rgba(0,0,0,0.08)";
      logo!.style.color = "#0a0a0a";
      navLinks.forEach((a) => ((a as HTMLElement).style.color = "#0a0a0a"));
    } else {
      nav!.style.background = "transparent";
      nav!.style.backdropFilter = "none";
      nav!.style.borderBottom = "none";
      logo!.style.color = "var(--color-cream)";
      navLinks.forEach((a) => ((a as HTMLElement).style.color = "var(--color-cream)"));
    }
  });
</script>

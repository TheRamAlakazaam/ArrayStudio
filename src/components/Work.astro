---
const projects = [
  {
    type: "Videography",
    title: "Brand Film — [Client Name]",
    desc: "A full brand story told in under two minutes. Concept, shoot, and post handled start to finish.",
    href: "#",
  },
  {
    type: "Photography",
    title: "Product Campaign — [Client Name]",
    desc: "Editorial-style product photography that elevated a local brand to national shelf presence.",
    href: "#",
  },
  {
    type: "Brand Identity",
    title: "Visual Rebrand — [Client Name]",
    desc: "Logo, brand system, and launch campaign for a company ready to stop playing small.",
    href: "#",
  },
];
---

<section id="work" class="bg-black px-12 py-[140px] text-center">

  <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-gold mb-6">
    // Selected work
  </p>
  <h2 class="font-playfair text-[clamp(44px,6vw,90px)] font-black text-cream leading-[0.95] mb-20">
    What we've<br /><em class="italic text-red">built.</em>
  </h2>

  <div class="grid grid-cols-3 gap-[2px] text-left">
    {
      projects.map((p) => (
        <a
          href={p.href}
          class="reveal group bg-white/[0.03] border border-white/[0.06] px-12 py-12 hover:bg-gold/[0.07] hover:border-gold/20 transition-all duration-300 no-underline block"
        >
          <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-red mb-4">
            {p.type}
          </p>
          <h3 class="font-playfair text-[26px] font-bold text-cream mb-3 leading-[1.2]">
            {p.title}
          </h3>
          <p class="font-mono text-[12px] leading-[1.8] text-cream/40">
            {p.desc}
          </p>
          <span class="inline-block mt-6 font-mono text-[11px] tracking-[0.15em] uppercase text-gold opacity-0 group-hover:opacity-100 transition-opacity duration-200">
            View Project →
          </span>
        </a>
      ))
    }
  </div>
</section>

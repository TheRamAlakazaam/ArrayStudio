---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";

const page = await getEntry("pages", "work");

if (!page) {
  throw new Error("Missing work page content entry.");
}

const { Content } = await render(page);

const engagements = [
  {
    title: "Public Art Program Launches",
    copy: "Narrative framing, artist storytelling, launch kits, social rollouts, event language, and campaign assets that help the program feel like a public moment.",
    tags: ["Public Art", "Launch Strategy", "Content"],
  },
  {
    title: "Placemaking and Destination Campaigns",
    copy: "Story-led campaigns for districts, developments, destinations, and neighborhood initiatives that need a sharper identity and stronger audience pull.",
    tags: ["Placemaking", "Identity", "Campaigns"],
  },
  {
    title: "Impact Initiatives",
    copy: "Messaging systems and creative campaigns for programs asking communities to engage, participate, contribute, or care over time.",
    tags: ["Impact", "Community", "Rollout"],
  },
];
---

<Layout title={page.data.seoTitle} description={page.data.seoDescription}>
  <PageHero eyebrow={page.data.eyebrow} title={page.data.title} intro={page.data.intro} />

  <section class="mx-auto grid max-w-[1440px] gap-6 px-6 py-12 md:px-10 lg:grid-cols-[0.9fr_1.1fr] lg:px-12 lg:py-14">
    <div class="content-panel prose-content p-5 md:p-6">
      <Content />
    </div>

    <div class="grid gap-3">
      {
        engagements.map((engagement) => (
          <div class="content-panel-dark p-5 text-white md:p-6">
            <h2 class="font-bebas text-[34px] font-bold leading-[0.98] tracking-[-0.05em] text-white">
              {engagement.title}
            </h2>
            <p class="mt-3 max-w-[42rem] font-mono text-[13px] leading-[1.85] text-white/68">
              {engagement.copy}
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              {engagement.tags.map((tag) => (
                <span class="rounded-full border border-white/14 px-3 py-2 font-mono text-[10px] uppercase tracking-[0.18em] text-white/72">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <CTA
    eyebrow="Need an outside partner?"
    title="If the program is real but the rollout still feels scattered, we can help tighten the whole system."
    intro="That can mean sharpening the story, restructuring the campaign, or building the creative and content pieces that help the work move in public."
  />
</Layout>

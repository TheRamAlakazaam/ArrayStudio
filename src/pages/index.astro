---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";

const home = await getEntry("pages", "home");

if (!home) {
  throw new Error("Missing home page content entry.");
}

const { Content } = await render(home);

const capabilityCards = [
  {
    title: "Strategy and Positioning",
    copy: "We sharpen the idea, frame the message, and build the language the rest of the campaign can actually follow.",
  },
  {
    title: "Creative and Content",
    copy: "Identity systems, launch visuals, photography, video, editorial storytelling, and social-ready assets built to feel cohesive.",
  },
  {
    title: "Rollout and Activation",
    copy: "From stakeholder decks to public-facing campaigns, we help the launch travel farther than the announcement.",
  },
];

const sectors = [
  "Public Art",
  "Placemaking",
  "Impact Programs",
  "Destinations",
  "Developers",
  "Cultural Institutions",
  "Community Campaigns",
  "Purpose-Led Brands",
];

const pageLinks = [
  {
    href: "/about/",
    title: "About",
    copy: "How we think, how we work, and why strategy has to stay close to the public-facing story.",
  },
  {
    href: "/services/",
    title: "Services",
    copy: "The full-service mix: positioning, campaigns, content, launch planning, and engagement systems.",
  },
  {
    href: "/work/",
    title: "Work",
    copy: "The categories of engagements we are built for and the kinds of rollout challenges we solve.",
  },
  {
    href: "/blog/",
    title: "Blog",
    copy: "Thoughts on public art, impact campaigns, placemaking, and building momentum in public.",
  },
];
---

<Layout title={home.data.seoTitle} description={home.data.seoDescription}>
  <section class="relative overflow-hidden border-b border-black/8 bg-[#f3fafe]">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute right-0 top-0 h-full w-[34rem] bg-[radial-gradient(circle_at_top_right,rgba(135,206,235,0.26),transparent_64%)]"></div>
      <div class="absolute left-0 bottom-0 h-48 w-48 bg-[radial-gradient(circle_at_bottom_left,rgba(255,107,74,0.08),transparent_70%)]"></div>
    </div>

    <div class="relative mx-auto max-w-[1440px] px-6 pb-12 pt-16 md:px-10 md:pb-14 md:pt-20 lg:px-12 lg:pb-16 lg:pt-22">
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.28em] text-[#ff6b4a]">{home.data.eyebrow}</p>
          <h1 class="display-title mt-4 max-w-[12ch] text-[clamp(40px,5.8vw,72px)] text-black">
            {home.data.title}
          </h1>
          <p class="mt-6 max-w-[42rem] font-mono text-[14px] leading-[1.95] text-black/68 md:text-[15px]">
            {home.data.intro}
          </p>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a
              href="/contact/"
              class="inline-flex items-center justify-center rounded-full bg-black px-7 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-white no-underline transition-transform duration-200 hover:-translate-y-0.5"
            >
              Start a Project
            </a>
            <a
              href="/services/"
              class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-7 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-black no-underline transition-colors duration-200 hover:border-black/20 hover:bg-white"
            >
              Explore Services
            </a>
          </div>
        </div>

        <div class="content-panel p-5 md:p-6">
          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-black/38">What we bring</p>
          <div class="mt-4">
            {
              capabilityCards.map((card, index) => (
                <div class:list={[
                  "grid gap-3 py-4 md:grid-cols-[80px_1fr]",
                  index !== capabilityCards.length - 1 && "border-b border-black/8",
                ]}>
                  <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[#2d9cdb]">
                    0{index + 1}
                  </p>
                  <div>
                    <h2 class="font-bebas text-[32px] font-bold leading-[0.98] tracking-[-0.05em] text-black">
                      {card.title}
                    </h2>
                    <p class="mt-2 font-mono text-[13px] leading-[1.85] text-black/62">{card.copy}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 py-6 md:px-10 lg:px-12">
    <div class="content-panel-dark p-4 md:p-5">
      <div class="flex flex-wrap gap-2">
        {sectors.map((item, index) => (
          <span
            class:list={[
              "rounded-full border px-4 py-2 font-mono text-[10px] uppercase tracking-[0.18em]",
              index % 3 === 0
                ? "border-[#87ceeb]/30 bg-[#87ceeb]/12 text-[#87ceeb]"
                : "border-white/10 bg-white/[0.04] text-white/72",
            ]}
          >
            {item}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-[1440px] gap-6 px-6 py-12 md:px-10 lg:grid-cols-[1fr_1fr] lg:px-12 lg:py-14">
    <div>
      <p class="font-mono text-[11px] uppercase tracking-[0.28em] text-[#ff6b4a]">Why Array Studio</p>
      <h2 class="section-title mt-5 max-w-[14ch] text-[clamp(38px,5.6vw,64px)] text-black">
        Not a one-off vendor. A campaign partner with range.
      </h2>
    </div>

    <div class="content-panel prose-content p-5 md:p-6">
      <Content />
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 pb-12 md:px-10 lg:px-12 lg:pb-14">
    <div class="content-panel p-4 md:p-5">
      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
      {
        pageLinks.map((link, index) => (
          <a
            href={link.href}
            class:list={[
              "group rounded-[20px] border border-black/8 p-5 no-underline transition-colors duration-200",
              index === 0
                ? "bg-[#e9f8fe] hover:bg-[#def3fd]"
                : index === 1
                  ? "bg-white hover:bg-[#f8fcff]"
                  : index === 2
                    ? "bg-[#111c24] text-white hover:bg-[#16232d]"
                    : "bg-white hover:bg-[#f8fcff]",
            ]}
          >
            <p class:list={[
              "font-mono text-[10px] uppercase tracking-[0.24em]",
              index === 2 ? "text-[#87ceeb]" : "text-[#ff6b4a]",
            ]}>Explore</p>
            <h3 class:list={[
              "mt-3 font-bebas text-[32px] font-bold leading-[0.98] tracking-[-0.05em]",
              index === 2 ? "text-white" : "text-black",
            ]}>
              {link.title}
            </h3>
            <p class:list={[
              "mt-3 font-mono text-[13px] leading-[1.85]",
              index === 2 ? "text-white/68" : "text-black/62",
            ]}>{link.copy}</p>
          </a>
        ))
      }
      </div>
    </div>
  </section>

  <CTA
    eyebrow="Built for public-facing work"
    title="When the story has to carry beyond the launch day, that is where we do our best work."
    intro="Whether you are introducing a public art program, rolling out a place-based campaign, or giving an impact initiative a stronger public voice, we can help shape the strategy and the rollout."
  />
</Layout>

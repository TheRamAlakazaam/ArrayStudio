---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Array Studio | Full-service marketing agency for public programs, places, and impact-led brands",
  description = "Array Studio is a full-service marketing agency specializing in public art, placemaking, and impact programs. We grow public programs and connect communities through storytelling.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&family=Syne:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      @import "tailwindcss";

      @theme {
        --color-black: #111c24;
        --color-cream: #fbfaf6;
        --color-warm-white: #f3fafe;
        --color-red: #ff6b4a;
        --color-gold: #2d9cdb;
        --color-mid-gray: #566572;
        --color-light-gray: #ccdae3;
        --color-blue: #87ceeb;

        --font-playfair: "Instrument Serif", serif;
        --font-mono: "IBM Plex Mono", monospace;
        --font-bebas: "Syne", sans-serif;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background:
          radial-gradient(circle at top right, rgba(135, 206, 235, 0.16), transparent 28%),
          linear-gradient(to right, rgba(17, 28, 36, 0.035) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(17, 28, 36, 0.035) 1px, transparent 1px),
          var(--color-warm-white);
        background-size: auto, 24px 24px, 24px 24px, auto;
        color: var(--color-black);
        font-family: var(--font-mono);
        overflow-x: hidden;
      }

      @keyframes ticker {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      .animate-ticker {
        animation: ticker 28s linear infinite;
      }

      .display-title {
        font-family: var(--font-playfair);
        font-weight: 400;
        letter-spacing: -0.025em;
        line-height: 0.98;
      }

      .section-title {
        font-family: var(--font-playfair);
        font-weight: 400;
        letter-spacing: -0.02em;
        line-height: 1;
      }

      .content-panel {
        border: 1px solid rgba(17, 28, 36, 0.08);
        border-radius: 1.35rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 252, 255, 0.92));
        box-shadow: 0 14px 44px rgba(17, 28, 36, 0.06);
        position: relative;
        overflow: hidden;
      }

      .content-panel::before {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, rgba(135, 206, 235, 0.9), rgba(45, 156, 219, 0.15));
      }

      .content-panel-dark {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1.35rem;
        background:
          linear-gradient(135deg, rgba(36, 61, 77, 0.34), transparent 45%),
          rgba(17, 28, 36, 0.97);
        position: relative;
        overflow: hidden;
      }

      .content-panel-dark::before {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, rgba(135, 206, 235, 0.95), rgba(255, 107, 74, 0.22));
      }

      .prose-content {
        color: rgba(17, 28, 36, 0.78);
        font-family: var(--font-mono);
        font-size: 0.95rem;
        line-height: 1.95;
      }

      .prose-content h2,
      .prose-content h3 {
        color: var(--color-black);
        font-family: var(--font-playfair);
        font-weight: 400;
        letter-spacing: -0.02em;
        line-height: 1.02;
        margin-top: 2rem;
        margin-bottom: 0.9rem;
      }

      .prose-content h2 {
        font-size: clamp(2rem, 4vw, 3.25rem);
      }

      .prose-content h3 {
        font-size: clamp(1.4rem, 2.5vw, 2rem);
      }

      .prose-content p,
      .prose-content ul,
      .prose-content ol,
      .prose-content blockquote {
        margin-bottom: 1rem;
      }

      .prose-content ul,
      .prose-content ol {
        padding-left: 1.2rem;
      }

      .prose-content a {
        color: var(--color-red);
        text-decoration: underline;
        text-underline-offset: 0.2em;
      }

      .prose-content strong {
        color: var(--color-black);
      }
    </style>
  </head>

  <body>
    <div class="relative min-h-screen">
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
